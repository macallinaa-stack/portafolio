<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Macarena Melo · Creative Technologist</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&family=Playfair+Display:ital@0;1&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg: #faf7f5;
  --text: #2d2d2d;
  --text-soft: #5a5a5a;
  --accent: #e84a5f;
  --accent-soft: #ffe2e8;
  --white: #ffffff;
  --border: #eaeaea;
  --shadow: 0 10px 30px -15px rgba(232,74,95,.2);
  --shadow-strong: 0 20px 40px -15px rgba(232,74,95,.3);
  --transition: all .3s ease;
  --font-serif: 'Playfair Display', serif;
  --font-sans: 'Quicksand', sans-serif;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box }
html { scroll-behavior:smooth }
body {
  background:var(--bg); color:var(--text);
  font-family:var(--font-sans); font-weight:400;
  line-height:1.6; overflow-x:hidden; cursor:none;
}
a, button { cursor:none; text-decoration:none }
section { position:relative; z-index:1 }
.wrap { max-width:1280px; margin:0 auto; padding:0 3rem }
@media (max-width:768px) { .wrap { padding:0 1.5rem } }

/* CURSOR */
#cursor {
  position:fixed; width:32px; height:32px;
  pointer-events:none; z-index:9999;
  transform:translate(-50%,-50%);
  transition:transform .2s ease, opacity .2s ease;
  filter:drop-shadow(0 4px 8px rgba(232,74,95,.4));
}
#cursor svg { width:100%; height:100%; fill:var(--accent); animation:heartbeat 1.2s ease-in-out infinite }
#cursor.hover { transform:translate(-50%,-50%) scale(1.6); filter:drop-shadow(0 8px 16px rgba(232,74,95,.5)) }
#cursor.hidden { opacity:0; }
@keyframes heartbeat {
  0%,100%{ transform:scale(1) }
  25%{ transform:scale(1.1) }
  35%{ transform:scale(1) }
  45%{ transform:scale(1.05) }
  55%{ transform:scale(1) }
}

/* MODAL — z-index MUY alto para estar siempre encima de todo */
#modal {
  position:fixed; inset:0;
  background:rgba(0,0,0,.95); backdrop-filter:blur(10px);
  z-index:99998;   /* debajo solo del botón X */
  display:none; align-items:center; justify-content:center;
  cursor:default;
  animation:fadeIn .25s ease;
}
#modal * { cursor:default }
#modal-inner {
  position:relative; width:90vw; height:90vh;
  display:flex; align-items:center; justify-content:center;
}
/* X SIEMPRE ENCIMA DE TODO — z-index máximo */
#modal-close {
  position:absolute; top:-44px; right:-44px;
  width:48px; height:48px; border-radius:50%;
  background:var(--accent); color:#fff; border:none;
  font-size:26px; line-height:1;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 20px rgba(232,74,95,.6);
  z-index:99999; /* el más alto de toda la página */
  transition:transform .2s ease, background .2s ease;
}
#modal-close:hover { transform:scale(1.15); background:#ff6b8b }
#modal-prev, #modal-next {
  position:absolute; top:50%; transform:translateY(-50%);
  width:52px; height:52px; border-radius:50%;
  background:rgba(255,255,255,.15); backdrop-filter:blur(4px);
  border:1px solid rgba(255,255,255,.25); color:#fff;
  font-size:26px; display:none; align-items:center; justify-content:center;
  transition:var(--transition);
  z-index:99998;
}
#modal-prev { left:12px }
#modal-next { right:12px }
#modal-prev:hover, #modal-next:hover {
  background:var(--accent); border-color:var(--accent);
  transform:translateY(-50%) scale(1.08);
}
#modal-counter {
  display:none; position:absolute; bottom:-38px; left:50%; transform:translateX(-50%);
  color:#fff; font-size:.9rem;
  background:rgba(0,0,0,.55); padding:.3rem 1.1rem;
  border-radius:50px; backdrop-filter:blur(4px);
  z-index:99998;
}
#modal-body { max-width:100%; max-height:90vh; display:flex; align-items:center; justify-content:center; }
#modal-body img, #modal-body video {
  max-width:min(100%, 620px); max-height:78vh; width:auto; height:auto; margin:0 auto;
  object-fit:contain; border-radius:8px;
  box-shadow:0 20px 40px rgba(0,0,0,.5); display:block;
}
@keyframes fadeIn { from{opacity:0} to{opacity:1} }

/* FLOATING DECOR */
#floating-decor { position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden }
.floating-item {
  position:absolute; font-family:var(--font-serif);
  color:var(--accent-soft); opacity:.15; font-size:2rem;
  animation:float 20s linear infinite;
}
@keyframes float {
  0%{ transform:translate(0,0) rotate(0deg) }
  33%{ transform:translate(30px,20px) rotate(120deg) }
  66%{ transform:translate(-20px,40px) rotate(240deg) }
  100%{ transform:translate(0,0) rotate(360deg) }
}

/* NAV */
nav {
  position:fixed; top:0; left:0; right:0; z-index:100;
  display:flex; justify-content:space-between; align-items:center;
  padding:1.25rem 3rem;
  background:rgba(255,255,255,.9); backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
}
.nav-logo { font-family:var(--font-serif); font-size:1.2rem; font-style:italic; color:var(--accent) }
.nav-links { display:flex; gap:3rem }
.nav-links a { font-size:.8rem; letter-spacing:.1em; text-transform:uppercase; color:var(--text-soft); transition:color .2s }
.nav-links a:hover { color:var(--accent) }
.lang-btn {
  background:var(--white); border:1px solid var(--border);
  border-radius:40px; padding:.4rem 1rem;
  font-size:.75rem; transition:var(--transition); font-family:var(--font-sans);
}
.lang-btn:hover { background:var(--accent-soft); border-color:var(--accent); transform:scale(1.02) }
@media (max-width:860px) { nav { padding:1rem 1.5rem } .nav-links { gap:1.5rem } }
@media (max-width:600px) { .nav-links { display:none } }

/* HERO */
.hero {
  min-height:100vh; display:flex; flex-direction:column;
  justify-content:center; padding:8rem 0 5rem;
  background:
    radial-gradient(circle at 10% 30%, var(--accent-soft) 0%, transparent 30%),
    radial-gradient(circle at 90% 70%, var(--accent-soft) 0%, transparent 30%);
}
.hero-inner { display:grid; grid-template-columns:1.2fr .9fr; gap:5rem; align-items:center }
@media (max-width:860px) { .hero-inner { grid-template-columns:1fr; gap:3rem } }
.hero-pill {
  display:inline-block; background:var(--white); color:var(--accent);
  padding:.4rem 1.5rem; border-radius:50px;
  font-size:.75rem; letter-spacing:.15em; text-transform:uppercase;
  border:1px solid var(--accent-soft); margin-bottom:2rem;
}
.hero-h1 {
  font-family:var(--font-serif); font-size:clamp(4rem,8vw,6rem);
  font-weight:400; line-height:1; margin-bottom:1rem;
}
.hero-h1 .italic {
  font-style:italic; color:var(--accent); position:relative; display:inline-block;
}
.hero-h1 .italic::after {
  content:'✦'; font-size:1.5rem; position:absolute;
  top:-10px; right:-25px; color:var(--accent); opacity:.5;
}
.hero-sub { font-size:1.2rem; color:var(--text-soft); margin-bottom:2rem; font-weight:300 }
.hero-bio {
  background:rgba(255,255,255,.9); backdrop-filter:blur(5px);
  padding:2rem; border-radius:16px; border:1px solid var(--accent-soft);
  margin-bottom:2.5rem; color:var(--text-soft); font-size:.95rem;
  line-height:1.8; max-width:550px;
}
.hero-bio p { margin-bottom:.8rem }
.hero-btns { display:flex; gap:1rem; flex-wrap:wrap }

/* BUTTONS */
.btn {
  display:inline-flex; align-items:center; gap:.6rem;
  padding:.8rem 2rem; border-radius:50px;
  font-size:.9rem; font-weight:500; transition:var(--transition);
  border:none; font-family:var(--font-sans);
}
.btn-primary  { background:var(--text); color:var(--white) }
.btn-primary:hover  { background:var(--accent); transform:translateY(-3px) }
.btn-secondary { background:transparent; border:1.5px solid var(--border); color:var(--text) }
.btn-secondary:hover { border-color:var(--accent); color:var(--accent); transform:translateY(-3px) }
.btn-outline  { background:transparent; border:2px solid var(--accent); color:var(--accent) }
.btn-outline:hover  { background:var(--accent); color:#fff; transform:translateY(-3px) }
.btn svg { width:16px; height:16px; stroke:currentColor; stroke-width:2; fill:none }

/* SKILL CARD */
.skill-card {
  background:var(--white); border-radius:24px; padding:2rem;
  border:1px solid var(--border); position:relative; box-shadow:var(--shadow);
  transition:var(--transition);
}
.skill-card:hover { border-color:var(--accent) }
.skill-pin {
  position:absolute; top:-12px; left:50%; transform:translateX(-50%);
  width:28px; height:28px; background:var(--accent); border-radius:50%;
  display:flex; align-items:center; justify-content:center; color:#fff;
  font-size:.8rem; box-shadow:0 4px 12px rgba(232,74,95,.4);
}
.skill-title { font-family:var(--font-serif); font-size:1.2rem; text-align:center; margin-bottom:1.5rem }
.skill-tags { display:flex; flex-wrap:wrap; gap:.5rem; justify-content:center; margin-bottom:1.5rem }
.skill-tag {
  background:var(--accent-soft); padding:.3rem 1rem; border-radius:50px;
  font-size:.75rem; color:var(--accent); font-weight:500;
}
.skill-divider { height:1px; background:var(--border); margin:1.2rem 0 }
.skill-langs { display:flex; justify-content:center; gap:2rem; font-size:.85rem; color:var(--text-soft) }
.skill-langs span { display:flex; align-items:center; gap:.3rem }
.skill-langs b { color:var(--accent); font-weight:500 }

/* SECTION HEADER */
.section-header { text-align:center; margin-bottom:4rem }
.section-eyebrow {
  display:inline-block; font-size:.75rem; letter-spacing:.2em;
  text-transform:uppercase; color:var(--accent); margin-bottom:.8rem;
  border-bottom:1px solid var(--accent-soft); padding-bottom:.2rem;
}
.section-title { font-family:var(--font-serif); font-size:clamp(2.5rem,5vw,3.5rem); font-weight:400 }
.section-title .accent { color:var(--accent); font-style:italic }

/* EXPERIENCE */
.exp-grid { display:grid; grid-template-columns:1fr 1fr; gap:2rem }
@media (max-width:700px) { .exp-grid { grid-template-columns:1fr } }
.exp-card {
  background:var(--white); border:1px solid var(--border);
  border-radius:20px; padding:2rem; transition:var(--transition); box-shadow:var(--shadow);
}
.exp-card:hover { transform:translateY(-5px); border-color:var(--accent); box-shadow:var(--shadow-strong) }
.exp-date { font-size:.7rem; letter-spacing:.1em; text-transform:uppercase; color:var(--accent); margin-bottom:.5rem }
.exp-role { font-family:var(--font-serif); font-size:1.6rem; font-weight:500; margin-bottom:.3rem }
.exp-co { font-size:.9rem; color:var(--text-soft); margin-bottom:1.5rem }
.exp-list { list-style:none }
.exp-list li { font-size:.9rem; color:var(--text-soft); padding-left:1.5rem; position:relative; margin-bottom:.6rem }
.exp-list li::before { content:'→'; position:absolute; left:0; color:var(--accent) }

/* TOOLS */
.tools-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:1rem; margin-top:2rem }
.tool-card {
  background:var(--white); border:1px solid var(--border);
  border-radius:12px; padding:1rem 1.5rem;
  display:flex; justify-content:space-between; align-items:center; transition:var(--transition);
}
.tool-card:hover { border-color:var(--accent); transform:translateX(5px) }
.tool-left { display:flex; align-items:center; gap:.8rem }
.tool-emoji { font-size:1.5rem }
.tool-name { font-weight:500; font-size:.9rem }
.tool-bar { width:80px; height:6px; background:var(--border); border-radius:10px; overflow:hidden }
.tool-fill { height:100%; background:var(--accent); width:0; border-radius:10px; transition:width 1s ease }

/* IA SECTION */
.ia-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.8rem; margin-top:2rem }
.ia-card {
  background:var(--white); border-radius:20px; padding:2rem;
  border:1px solid var(--border); box-shadow:var(--shadow);
  transition:var(--transition); display:flex; flex-direction:column; gap:1rem;
}
.ia-card:hover { transform:translateY(-5px); border-color:var(--accent); box-shadow:var(--shadow-strong) }
.ia-icon { font-size:2.5rem }
.ia-card h3 { font-family:var(--font-serif); font-size:1.4rem; color:var(--accent) }
.ia-card p { color:var(--text-soft); font-size:.95rem; line-height:1.6 }
.ia-tags { display:flex; flex-wrap:wrap; gap:.5rem; margin-top:.5rem }
.ia-tag { background:var(--accent-soft); padding:.2rem 1rem; border-radius:50px; font-size:.75rem; color:var(--accent) }

/* APORTAR */
.aportar-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:1.8rem; margin-top:2rem }
.aportar-card {
  background:var(--white); border-radius:30px; padding:2rem;
  box-shadow:var(--shadow); border:1px solid var(--border); transition:var(--transition);
}
.aportar-card:hover { transform:translateY(-5px); box-shadow:var(--shadow-strong); border-color:var(--accent) }
.aportar-card.destacada {
  border:2px solid var(--accent); box-shadow:var(--shadow-strong);
  transform:scale(1.02); position:relative; overflow:hidden;
}
.aportar-card.destacada::before {
  content:'✨'; position:absolute; top:-20px; right:-20px;
  font-size:5rem; opacity:.1; transform:rotate(15deg); pointer-events:none;
}
.aportar-icon {
  font-size:2.5rem; background:var(--accent-soft); width:60px; height:60px;
  display:flex; align-items:center; justify-content:center; border-radius:20px; margin-bottom:1rem;
}
.aportar-title { font-family:var(--font-serif); font-size:1.6rem; color:var(--accent); line-height:1.2; margin-bottom:.5rem }
.aportar-sub { color:var(--text-soft); font-size:.9rem; margin-bottom:1rem }
.aportar-tags { display:flex; flex-wrap:wrap; gap:.5rem; margin-top:1rem }
.aportar-tag { background:var(--accent-soft); padding:.3rem 1rem; border-radius:50px; font-size:.8rem }
.aportar-mini-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1rem; margin-top:2rem }
.aportar-mini-card {
  background:rgba(255,255,255,.7); backdrop-filter:blur(5px);
  border-radius:20px; padding:1.5rem; border:1px solid var(--border);
  text-align:center; transition:var(--transition);
}
.aportar-mini-card:hover { background:var(--white); transform:translateY(-3px) }
.aportar-mini-emoji { font-size:2rem; margin-bottom:.5rem }
.aportar-mini-title { font-weight:600; margin-bottom:.3rem }
.aportar-mini-text { font-size:.8rem; color:var(--text-soft) }
.aportar-badge {
  background:var(--accent); color:#fff; display:inline-block;
  padding:1rem 3rem; border-radius:60px; box-shadow:0 20px 30px -10px var(--accent);
  transform:rotate(-1deg); font-family:var(--font-serif); font-size:1.8rem;
  font-style:italic; margin-top:4rem;
}

/* EDUCATION */
.edu-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2rem; margin-top:2rem }
.edu-card {
  background:var(--white); border:1px solid var(--border);
  border-radius:20px; padding:1.5rem; transition:var(--transition); box-shadow:var(--shadow);
}
.edu-card:hover { border-color:var(--accent); transform:translateY(-5px) }
.edu-title { font-family:var(--font-serif); font-size:1.1rem; font-weight:500; margin-bottom:.5rem }
.edu-institution { color:var(--accent); margin-bottom:.3rem; font-size:.9rem }
.edu-year {
  font-size:.8rem; color:var(--text-soft);
  background:var(--accent-soft); display:inline-block;
  padding:.2rem 1rem; border-radius:50px;
}

/* PROJECTS */
.projects-grid {
  display:grid; grid-template-columns:repeat(3,1fr);
  gap:1.5rem; margin-top:2rem;
}
@media (max-width:1000px) { .projects-grid { grid-template-columns:repeat(2,1fr) } }
@media (max-width:600px)  { .projects-grid { grid-template-columns:1fr } }

.project-card {
  background:var(--white); border-radius:20px; overflow:hidden;
  border:1px solid var(--border); box-shadow:var(--shadow);
  transition:var(--transition); display:flex; flex-direction:column;
}
.project-card:hover { transform:translateY(-5px); border-color:var(--accent); box-shadow:var(--shadow-strong) }

.project-media {
  position:relative;
  width:100%; height:210px;
  background:var(--accent-soft);
  overflow:hidden;
}
.project-media img, .project-media video {
  position:absolute; inset:0;
  width:100%; height:100%;
  object-fit:cover; object-position:top center;
  transition:transform .4s ease;
  display:block;
}
.project-card:hover .project-media img { transform:scale(1.04) }

.media-badge {
  position:absolute; top:10px; right:10px;
  background:rgba(0,0,0,.55); backdrop-filter:blur(4px);
  color:#fff; width:32px; height:32px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:1rem; z-index:2; pointer-events:none;
}
.multi-badge {
  position:absolute; bottom:10px; right:10px;
  background:var(--accent); color:#fff;
  padding:.2rem .8rem; border-radius:50px;
  font-size:.7rem; font-weight:600; z-index:2; pointer-events:none;
}

.project-info { padding:1.5rem; flex:1; display:flex; flex-direction:column }
.project-info h4 { font-family:var(--font-serif); font-size:1.2rem; margin-bottom:.5rem }
.project-tools-mini { display:flex; flex-wrap:wrap; gap:.4rem; margin-bottom:1rem }
.tool-mini { background:var(--accent-soft); color:var(--accent); padding:.2rem .6rem; border-radius:30px; font-size:.65rem; font-weight:500 }
.project-actions { display:flex; gap:.8rem; margin-top:auto; align-items:center; flex-wrap:wrap }
.project-btn, a.project-btn {
  flex:1; padding:.55rem 1rem; border-radius:30px; font-size:.8rem; font-weight:600;
  text-align:center; transition:var(--transition);
  border:1.5px solid var(--border);
  background:var(--white); color:var(--text-soft);
  font-family:var(--font-sans);
  display:inline-flex; align-items:center; justify-content:center;
  line-height:1; text-decoration:none;
}
.project-btn.primary, a.project-btn.primary {
  background:var(--accent); color:#fff !important;
  border-color:var(--accent);
}
.project-btn:hover, a.project-btn:hover { transform:translateY(-2px); box-shadow:var(--shadow) }
.project-btn.primary:hover, a.project-btn.primary:hover { background:#ff6b8b; border-color:#ff6b8b }

.project-gallery { display:grid; grid-template-columns:repeat(2,1fr); gap:.5rem; margin-bottom:1rem }
.gallery-item { aspect-ratio:1/1; background:var(--accent-soft); border-radius:10px; overflow:hidden }
.gallery-item img { width:100%; height:100%; object-fit:cover; transition:var(--transition) }
.gallery-item:hover img { transform:scale(1.1) }

.proj-category-header { margin:4rem 0 2rem; padding-bottom:1rem; border-bottom:2px dashed var(--accent-soft) }
.proj-category-header h3 { font-family:var(--font-serif); font-size:2rem; color:var(--accent); margin-bottom:.3rem }
.proj-category-header p { color:var(--text-soft); max-width:700px }

/* CARRUSEL */
.carrusel {
  position:relative; width:100%; aspect-ratio:16/9;
  overflow:hidden; border-radius:12px; margin-bottom:1rem;
}
.carrusel-track { display:flex; height:100%; transition:transform .3s ease }
.carrusel-slide { flex:0 0 100%; height:100% }
.carrusel-slide img { width:100%; height:100%; object-fit:cover }
.carrusel-btn {
  position:absolute; top:50%; transform:translateY(-50%);
  width:30px; height:30px; border-radius:50%;
  background:rgba(255,255,255,.8); border:none; color:var(--accent);
  font-size:1.2rem; display:flex; align-items:center; justify-content:center;
  z-index:2; transition:var(--transition); font-family:var(--font-sans);
}
.carrusel-btn:hover { background:var(--accent); color:#fff }
.carrusel-prev { left:10px }
.carrusel-next { right:10px }
.carrusel-dots { display:flex; justify-content:center; gap:.3rem; margin-top:.5rem }
.carrusel-dot {
  width:6px; height:6px; border-radius:50%; background:var(--border);
  border:none; transition:var(--transition);
}
.carrusel-dot.active { background:var(--accent); transform:scale(1.4) }

/* BACK TO TOP */
.back-to-top {
  position:fixed; bottom:2rem; right:2rem;
  width:56px; height:56px; border-radius:50%;
  background:var(--accent); color:#fff; border:none;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 4px 20px rgba(232,74,95,.4); transition:all .3s ease;
  z-index:999; opacity:0; visibility:hidden; transform:translateY(10px);
}
.back-to-top.visible { opacity:1; visibility:visible; transform:translateY(0) }
.back-to-top:hover { background:#ff6b8b; transform:translateY(-3px) scale(1.1); box-shadow:0 8px 25px rgba(232,74,95,.6) }

/* FOOTER */
footer {
  background:var(--text); color:var(--white);
  padding:6rem 2rem 3rem; text-align:center; margin-top:4rem;
  position:relative; overflow:hidden;
}
footer::before {
  content:'♡ ♡ ♡'; position:absolute; top:20px; left:0; width:100%;
  font-size:4rem; opacity:.08; color:var(--accent); letter-spacing:.3em;
  animation:slide 20s linear infinite; pointer-events:none;
}
@keyframes slide { from{transform:translateX(-50%)} to{transform:translateX(50%)} }
footer h2 { font-family:var(--font-serif); font-size:clamp(2.5rem,5vw,3rem); font-weight:400; margin-bottom:1rem; color:#fff }
.footer-sub { color:var(--accent-soft); margin-bottom:2.5rem; font-size:1.1rem }
.footer-links { display:flex; justify-content:center; gap:2rem; flex-wrap:wrap; margin-bottom:3rem }
.footer-links a {
  color:var(--white); font-size:.95rem; transition:var(--transition);
  display:inline-flex; align-items:center; gap:.6rem;
  background:rgba(255,255,255,.08); padding:.6rem 1.8rem;
  border-radius:50px; border:1px solid rgba(255,255,255,.1);
}
.footer-links a:hover { background:var(--accent); transform:translateY(-3px); border-color:var(--accent) }
.footer-copyright { font-size:.8rem; opacity:.5 }
@media (max-width:768px) {
  .back-to-top { bottom:1.5rem; right:1.5rem; width:48px; height:48px }
  .footer-links { gap:1rem }
  .footer-links a { padding:.5rem 1.2rem; font-size:.85rem }
}

/* REVEAL */
.reveal { opacity:0; transform:translateY(40px); transition:opacity .8s ease, transform .8s ease }
.reveal.visible { opacity:1; transform:translateY(0) }
.delay-1 { transition-delay:.1s }
.delay-2 { transition-delay:.2s }
.delay-3 { transition-delay:.3s }

.cat-label { font-size:1.2rem; margin:2rem 0 1rem; font-weight:400; color:var(--accent); text-align:center; }
</style>
</head>
<body>

<div id="cursor" aria-hidden="true">
  <svg viewBox="0 0 32 32">
    <path d="M16 27s-1-.8-2.5-2C9 21.4 4 17.2 4 11.5 4 8 6.7 5 10.5 5c2 0 3.9 1 5.5 2.8C17.6 6 19.5 5 21.5 5 25.3 5 28 8 28 11.5c0 5.7-5 9.9-9.5 13.5C17 26.2 16 27 16 27z"/>
  </svg>
</div>

<div id="floating-decor" aria-hidden="true">
  <div class="floating-item" style="top:10%;left:5%">✦</div>
  <div class="floating-item" style="top:30%;right:8%;animation-delay:-2s">✧</div>
  <div class="floating-item" style="bottom:20%;left:12%;animation-delay:-5s">♢</div>
  <div class="floating-item" style="bottom:40%;right:15%;animation-delay:-8s">✤</div>
</div>

<nav>
  <a href="#inicio" class="nav-logo">Macarena Melo</a>
  <div class="nav-links" id="nav-links">
    <a href="#experiencia" id="nav-experiencia">Experiencia</a>
    <a href="#habilidades" id="nav-skills">Skills</a>
    <a href="#proyectos" id="nav-proyectos">Proyectos</a>
    <a href="#ia" id="nav-ia">IA</a>
    <a href="#aportar" id="nav-aportar">Aportar</a>
    <a href="#contacto" id="nav-contacto">Contacto</a>
  </div>
  <button class="lang-btn" id="lang-btn">🇺🇸 EN</button>
</nav>

<!-- HERO -->
<section class="hero" id="inicio">
  <div class="wrap">
    <div class="hero-inner">
      <div class="reveal">
        <span class="hero-pill" id="hero-pill">✦ Buenos Aires, Argentina</span>
        <h1 class="hero-h1">Macarena <span class="italic">Melo.</span></h1>
        <p class="hero-sub" id="hero-rol">Growth Product Designer Jr. + UX/UI Strategist Jr.</p>
        <div class="hero-bio">
          <p id="hero-bio1">¡Hola! Soy Macarena, una Growth Product Designer Jr. que une diseño UX, marketing digital y growth hacking para generar impacto real. Me encanta crear piezas atractivas, cómodas y que conviertan.</p>
          <p id="hero-bio2">✨ Diseño UX: Interfaces intuitivas con Figma y Adobe XD.<br>📈 Growth: Landing pages optimizadas y Ads estratégicas.<br>🎨 Diseño integral: Identidad visual, posts, emails y automatizaciones.</p>
        </div>
        <div class="hero-btns">
          <a href="#proyectos" class="btn btn-primary" id="btn-proyectos">
            <span>Ver proyectos</span>
            <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={`https://mail.google.com/mail/?view=cm&to=${email}`} target="_blank" rel="noopener noreferrer" class="btn btn-secondary" id="btn-contacto">
            <span>Enviar mensaje</span>
            <svg viewBox="0 0 24 24"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
          </a>
          <a href={portfolioFigma} target="_blank" rel="noopener noreferrer" class="btn btn-outline" id="btn-figma">
            <span>Ver presentación</span>
            <svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
          </a>
        </div>
      </div>
      <div class="skill-card reveal delay-1">
        <div class="skill-pin" aria-hidden="true">✦</div>
        <h3 class="skill-title" id="skill-titulo">Lo que puedo hacer</h3>
        <div class="skill-tags">
          <span class="skill-tag">UX/UI Design</span>
          <span class="skill-tag">Growth Marketing</span>
          <span class="skill-tag">Branding</span>
          <span class="skill-tag">Social Media</span>
          <span class="skill-tag">Email Marketing</span>
          <span class="skill-tag">IA + Desarrollo</span>
        </div>
        <div class="skill-divider"></div>
        <div class="skill-langs">
          <span>🇦🇷 <b id="skill-espanol">Español</b> <span id="skill-nativo">nativo</span></span>
          <span>🇺🇸 <b id="skill-ingles">Inglés</b> B1</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- EXPERIENCIA -->
<section id="experiencia" style="padding:5rem 0">
  <div class="wrap">
    <div class="section-header reveal">
      <span class="section-eyebrow" id="exp-eyebrow">✦ Trayectoria</span>
      <h2 class="section-title">Mi <span class="accent" id="exp-titulo">experiencia</span></h2>
    </div>
    <div class="exp-grid">
      {experiencia.map((exp, i) => (
        <div class="exp-card reveal" style={`transition-delay:${0.1 * i}s`}>
          <div class="exp-date">{exp.fecha}</div>
          <h3 class="exp-role">{exp.rol}</h3>
          <p class="exp-co">{exp.empresa}</p>
          <ul class="exp-list">
            {exp.items.map(item => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- HABILIDADES -->
<section id="habilidades" style="background:var(--white);padding:5rem 0">
  <div class="wrap">
    <div class="section-header reveal">
      <span class="section-eyebrow" id="skills-eyebrow">✦ Skills</span>
      <h2 class="section-title"><span id="skills-titulo">Herramientas</span> <span class="accent" id="skills-titulo-span">y tecnologías</span></h2>
    </div>
    <div style="margin-bottom:3rem">
      <h3 class="cat-label" id="estudios-titulo">Estudios y cursos</h3>
      <div class="edu-grid">
        {educacion.map(edu => (
          <div class="edu-card">
            <h4 class="edu-title">{edu.titulo}</h4>
            <p class="edu-institution">{edu.institucion}</p>
            <span class="edu-year">{edu.anio}</span>
          </div>
        ))}
      </div>
    </div>
    <h3 class="cat-label" id="design-cat">Diseño</h3>
    <div class="tools-grid reveal">
      {herramientas.filter(t => t.category === 'design').map(t => (
        <div class="tool-card">
          <div class="tool-left"><span class="tool-emoji">{t.emoji}</span><span class="tool-name">{t.name}</span></div>
          <div class="tool-bar"><div class="tool-fill" data-level={t.level}></div></div>
        </div>
      ))}
    </div>
    <h3 class="cat-label" id="dev-cat">Desarrollo</h3>
    <div class="tools-grid reveal">
      {herramientas.filter(t => t.category === 'dev').map(t => (
        <div class="tool-card">
          <div class="tool-left"><span class="tool-emoji">{t.emoji}</span><span class="tool-name">{t.name}</span></div>
          <div class="tool-bar"><div class="tool-fill" data-level={t.level}></div></div>
        </div>
      ))}
    </div>
    <h3 class="cat-label" id="marketing-cat">Marketing & Growth</h3>
    <div class="tools-grid reveal">
      {herramientas.filter(t => ['marketing','analytics','prod'].includes(t.category)).map(t => (
        <div class="tool-card">
          <div class="tool-left"><span class="tool-emoji">{t.emoji}</span><span class="tool-name">{t.name}</span></div>
          <div class="tool-bar"><div class="tool-fill" data-level={t.level}></div></div>
        </div>
      ))}
    </div>
    <h3 class="cat-label" id="ia-cat">IA & Despliegue</h3>
    <div class="tools-grid reveal">
      {herramientas.filter(t => ['ia','devops'].includes(t.category)).map(t => (
        <div class="tool-card">
          <div class="tool-left"><span class="tool-emoji">{t.emoji}</span><span class="tool-name">{t.name}</span></div>
          <div class="tool-bar"><div class="tool-fill" data-level={t.level}></div></div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- PROYECTOS -->
<div id="proyectos" style="padding:2rem 0"></div>

{proyectos.map((cat) => (
  <div style="margin-bottom:4rem">
    <div class="wrap">
      <div class="proj-category-header reveal">
        <h3>{cat.categoria}</h3>
        <p>{cat.descripcion}</p>
        <div style="display:flex;gap:.5rem;margin-top:1rem;flex-wrap:wrap">
          {cat.tools.map(tool => <span class="tool-mini">{tool}</span>)}
        </div>
      </div>
      <div class="projects-grid">
        {cat.proyectos.map((proy, i) => {
          const catId = cat.id;
          return (
            <div class="project-card reveal" style={`transition-delay:${.05*i}s`}>
              <div class="project-media">
                {proy.tipo === 'video' && (
                  <>
                    <video src={proy.url} muted loop playsinline></video>
                    <span class="media-badge">▶️</span>
                  </>
                )}
                {proy.tipo === 'imagen' && proy.archivo && !proy.archivos && (
                  <>
                    <img src={`/imagenes/${catId}/${proy.archivo}`} alt={proy.nombre} loading="lazy" />
                    <span class="media-badge">🖼️</span>
                  </>
                )}
                {proy.archivos && proy.archivos.length > 0 && (
                  <>
                    <img src={`/imagenes/${catId}/${proy.archivos[0]}`} alt={proy.nombre} loading="lazy" />
                    <span class="media-badge">🖼️</span>
                    <span class="multi-badge">+{proy.archivos.length}</span>
                  </>
                )}
                {proy.tipo === 'mix' && proy.items && (
                  <>
                    {proy.items.find(x => x.tipo === 'imagen') ? (
                      <img src={`/imagenes/${catId}/${proy.items.find(x => x.tipo === 'imagen').archivo}`} alt={proy.nombre} loading="lazy" />
                    ) : (
                      <video src={proy.items.find(x => x.tipo === 'video').url} muted loop playsinline></video>
                    )}
                    <span class="media-badge">🎬</span>
                    <span class="multi-badge">{proy.items.length} archivos</span>
                  </>
                )}
                {proy.tipo === 'carrusel' && proy.archivos && (
                  <>
                    <div class="carrusel" id={`c-${catId}-${i}`}>
                      <div class="carrusel-track">
                        {proy.archivos.map((a, idx) => (
                          <div class="carrusel-slide" key={idx}>
                            <img src={`/imagenes/${catId}/${a}`} alt={`${proy.nombre} ${idx+1}`} loading="lazy" />
                          </div>
                        ))}
                      </div>
                      <button class="carrusel-btn carrusel-prev" onclick={`carruselMover('${catId}-${i}',-1);event.stopPropagation()`}>‹</button>
                      <button class="carrusel-btn carrusel-next" onclick={`carruselMover('${catId}-${i}',1);event.stopPropagation()`}>›</button>
                    </div>
                    <div class="carrusel-dots" id={`d-${catId}-${i}`}>
                      {proy.archivos.map((_, idx) => (
                        <button class={`carrusel-dot${idx===0?' active':''}`} onclick={`carruselIr('${catId}-${i}',${idx});event.stopPropagation()`}></button>
                      ))}
                    </div>
                  </>
                )}
              </div>

              <div class="project-info">
                <h4>{proy.nombre}</h4>
                {proy.archivos && proy.tipo !== 'carrusel' && (
                  <div class="project-gallery">
                    {proy.archivos.slice(0,2).map((arch, idx) => (
                      <div class="gallery-item" onclick={`modalImagen('${catId}','${arch}','${proy.nombre}')`} key={idx}>
                        <img src={`/imagenes/${catId}/${arch}`} alt={`${proy.nombre} ${idx+1}`} loading="lazy" />
                      </div>
                    ))}
                  </div>
                )}
                {proy.tipo === 'mix' && proy.items && (
                  <div class="project-gallery">
                    {proy.items.filter(x => x.tipo === 'imagen').slice(0,2).map((item, idx) => (
                      <div class="gallery-item" onclick={`modalImagen('${catId}','${item.archivo}','${proy.nombre}')`} key={idx}>
                        <img src={`/imagenes/${catId}/${item.archivo}`} alt={`${proy.nombre} ${idx+1}`} loading="lazy" />
                      </div>
                    ))}
                  </div>
                )}
                <div class="project-tools-mini">
                  {proy.tipo === 'video' && <span class="tool-mini">🎬 Video</span>}
                  {proy.tipo === 'carrusel' && proy.archivos && <span class="tool-mini">📸 {proy.archivos.length} imágenes</span>}
                  {proy.tipo === 'mix' && <span class="tool-mini">🎬 Mix</span>}
                </div>
                <div class="project-actions">
                  {proy.tipo === 'video' && (
                    <button class="project-btn primary" onclick={`modalVideo('${proy.url}','${proy.nombre}')`}>Ver video</button>
                  )}
                  {proy.tipo === 'carrusel' && proy.archivos && (
                    <button class="project-btn primary" onclick={`modalGaleria('${catId}',${JSON.stringify(proy.archivos)},'${proy.nombre}')`}>Ver galería</button>
                  )}
                  {proy.tipo === 'imagen' && proy.archivo && !proy.archivos && (
                    <button class="project-btn primary" onclick={`modalImagen('${catId}','${proy.archivo}','${proy.nombre}')`}>Ver imagen</button>
                  )}
                  {proy.archivos && proy.tipo !== 'carrusel' && (
                    <button class="project-btn primary" onclick={`modalGaleria('${catId}',${JSON.stringify(proy.archivos)},'${proy.nombre}')`}>Ver galería</button>
                  )}
                  {proy.tipo === 'mix' && proy.items && (
                    <button class="project-btn primary" onclick={`modalMix('${catId}',${JSON.stringify(proy.items)},'${proy.nombre}')`}>Ver todo</button>
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
))}

