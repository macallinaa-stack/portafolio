<script>
const cursor = document.getElementById('cursor');
document.addEventListener('mousemove', e => {
  cursor.style.left = e.clientX + 'px';
  cursor.style.top  = e.clientY + 'px';
});
document.querySelectorAll('a,button,.exp-card,.tool-card,.edu-card,.project-card,.aportar-card,.aportar-mini-card,.ia-card,.gallery-item,.carrusel-btn,.carrusel-dot').forEach(el => {
  el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
  el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
});

// ── MODAL ──────────────────────────────────────────────
let modalItems = [], modalIdx = 0;
const modal        = document.getElementById('modal');
const modalBody    = document.getElementById('modal-body');
const modalClose   = document.getElementById('modal-close');
const modalPrev    = document.getElementById('modal-prev');
const modalNext    = document.getElementById('modal-next');
const modalCounter = document.getElementById('modal-counter');

function modalShow() {
  renderModal();
  const many = modalItems.length > 1;
  modalPrev.style.display    = many ? 'flex' : 'none';
  modalNext.style.display    = many ? 'flex' : 'none';
  modalCounter.style.display = many ? 'block' : 'none';
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
  cursor.classList.add('hidden'); // ocultar cursor custom
}

function renderModal() {
  const item = modalItems[modalIdx];
  if (!item) return;
  if (item.type === 'image') {
    modalBody.innerHTML = `<img src="${item.src}" alt="${item.titulo}">`;
  } else {
    modalBody.innerHTML = `<video src="${item.src}" controls autoplay></video>`;
  }
  if (modalItems.length > 1) modalCounter.textContent = `${modalIdx+1} / ${modalItems.length}`;
}

function closeModal() {
  // Pausar y limpiar video antes de cerrar
  const v = modalBody.querySelector('video');
  if (v) { v.pause(); v.removeAttribute('src'); v.load(); }
  modal.style.display = 'none';
  document.body.style.overflow = '';
  cursor.classList.remove('hidden'); // restaurar cursor
}

window.modalImagen = (catId, archivo, titulo) => {
  modalItems = [{ type:'image', src:`/imagenes/${catId}/${archivo}`, titulo }];
  modalIdx = 0; modalShow();
};
window.modalVideo = (url, titulo) => {
  modalItems = [{ type:'video', src:url, titulo }];
  modalIdx = 0; modalShow();
};
window.modalGaleria = (catId, archivos, titulo) => {
  const arr = Array.isArray(archivos) ? archivos : JSON.parse(archivos);
  modalItems = arr.map(a => ({ type:'image', src:`/imagenes/${catId}/${a}`, titulo }));
  modalIdx = 0; modalShow();
};
window.modalMix = (catId, items, titulo) => {
  const arr = Array.isArray(items) ? items : JSON.parse(items);
  modalItems = arr.map(x => ({
    type: x.tipo === 'video' ? 'video' : 'image',
    src:  x.tipo === 'video' ? x.url : `/imagenes/${catId}/${x.archivo}`,
    titulo
  }));
  modalIdx = 0; modalShow();
};

// Botón X — cierra el modal
modalClose.addEventListener('click', e => { e.stopPropagation(); closeModal(); });

// Prev / Next
modalPrev.addEventListener('click', e => {
  e.stopPropagation();
  modalIdx = (modalIdx - 1 + modalItems.length) % modalItems.length;
  renderModal();
});
modalNext.addEventListener('click', e => {
  e.stopPropagation();
  modalIdx = (modalIdx + 1) % modalItems.length;
  renderModal();
});

// Click fuera del contenido cierra
modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });

// Teclado
document.addEventListener('keydown', e => {
  if (modal.style.display !== 'flex') return;
  if (e.key === 'Escape')     closeModal();
  if (e.key === 'ArrowLeft')  { modalIdx = (modalIdx-1+modalItems.length)%modalItems.length; renderModal(); }
  if (e.key === 'ArrowRight') { modalIdx = (modalIdx+1)%modalItems.length; renderModal(); }
});

// ── CARRUSEL ───────────────────────────────────────────
window.carruselMover = (uid, dir) => {
  const c = document.getElementById(`c-${uid}`);
  if (!c) return;
  const track = c.querySelector('.carrusel-track');
  const total = track.children.length;
  const m = track.style.transform.match(/-?(\d+)/);
  let cur = m ? Math.abs(parseInt(m[1])/100) : 0;
  cur = (cur + dir + total) % total;
  track.style.transform = `translateX(-${cur*100}%)`;
  document.querySelectorAll(`#d-${uid} .carrusel-dot`).forEach((d,i) => d.classList.toggle('active', i===cur));
};
window.carruselIr = (uid, idx) => {
  const c = document.getElementById(`c-${uid}`);
  if (!c) return;
  c.querySelector('.carrusel-track').style.transform = `translateX(-${idx*100}%)`;
  document.querySelectorAll(`#d-${uid} .carrusel-dot`).forEach((d,i) => d.classList.toggle('active', i===idx));
};

// ── SCROLL REVEAL ──────────────────────────────────────
new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold:0.1 }).observe = (() => {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold:0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
  return obs.observe.bind(obs);
})();

// ── SKILL BARS ─────────────────────────────────────────
new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) e.target.style.width = (parseInt(e.target.dataset.level)/5*100)+'%';
  });
}, { threshold:0.3 }).observe = (() => {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) e.target.style.width = (parseInt(e.target.dataset.level)/5*100)+'%';
    });
  }, { threshold:0.3 });
  document.querySelectorAll('.tool-fill').forEach(b => obs.observe(b));
  return obs.observe.bind(obs);
})();

// ── BACK TO TOP ────────────────────────────────────────
const btt = document.getElementById('back-to-top');
window.addEventListener('scroll', () => btt.classList.toggle('visible', window.scrollY > 300));
btt.addEventListener('click', () => window.scrollTo({ top:0, behavior:'smooth' }));

// ── IDIOMA ─────────────────────────────────────────────
